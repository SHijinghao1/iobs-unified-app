<?xml version="1.0" encoding="utf-8"?>
<robot name="surgical_bed_v2">

  <!-- 底座 -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="120.0" />
      <inertia ixx="10" ixy="0" ixz="0" iyy="10" iyz="0" izz="10" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_base_new_bin.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="base_gray">
        <color rgba="0.75 0.77 0.80 1.0" />
      </material>
    </visual>
  </link>

  <!-- 前后移中间链路 -->
  <link name="bed_front_back_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>

  <!-- 前后倾中间链路 -->
  <link name="bed_tilt_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>

  <!-- 左右倾中间链路 -->
  <link name="bed_lateral_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>

  <!-- 中间床板（作为可动主链） -->
  <link name="bed_panel_mid">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="-0.01 0.1 0.08" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_panel_mid_new.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="panel_gray">
        <color rgba="0.85 0.87 0.90 1.0" />
      </material>
    </visual>
  </link>

  <!-- 前后移：base_link -> bed_front_back_link -->
  <joint name="bed_front_back_joint" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="bed_front_back_link" />
    <axis xyz="0 1 0" />
    <limit lower="-0.5" upper="0.5" effort="500" velocity="0.1" />
    <dynamics damping="10" friction="0" />
  </joint>

  <!-- 前后倾：bed_front_back_link -> bed_tilt_link -->
  <joint name="bed_tilt_joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="bed_front_back_link" />
    <child link="bed_tilt_link" />
    <axis xyz="1 0 0" />
    <limit lower="-0.261799" upper="0.261799" effort="100" velocity="0.5" />
    <dynamics damping="5" friction="0" />
  </joint>

  <!-- 左右倾：bed_tilt_link -> bed_lateral_link -->
  <joint name="bed_lateral_joint" type="revolute">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="bed_tilt_link" />
    <child link="bed_lateral_link" />
    <axis xyz="0 1 0" />
    <limit lower="-0.261799" upper="0.261799" effort="100" velocity="0.5" />
    <dynamics damping="5" friction="0" />
  </joint>

  <!-- 升降：bed_lateral_link -> bed_panel_mid -->
  <joint name="bed_height_joint" type="prismatic">
    <origin xyz="0 0.68 0.1761" rpy="0 0 0" />
    <parent link="bed_lateral_link" />
    <child link="bed_panel_mid" />
    <axis xyz="0 0 1" />
    <limit lower="-0.5" upper="0.5" effort="500" velocity="0.1" />
    <dynamics damping="10" friction="0" />
  </joint>

  <!-- 右大腿板 -->
  <link name="bed_panel_right_leg">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="0.235 0.00 0.08" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_panel_left_leg_lower_new.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="panel_gray">
        <color rgba="0.85 0.87 0.90 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_panel_right_leg_joint" type="revolute">
    <origin xyz="-0.2435 0.16 0.4309" rpy="0 0 0" />
    <parent link="bed_panel_mid" />
    <child link="bed_panel_right_leg" />
    <axis xyz="1 0 0" />
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="0.1" />
    <dynamics damping="5" friction="0" />
  </joint>

  <!-- 右小腿板（独立运动） -->
  <link name="bed_panel_right_leg_lower">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="-0.235 0.00 -0.21" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_panel_left_leg_upper_new.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="panel_gray">
        <color rgba="0.85 0.87 0.90 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_panel_right_leg_lower_joint" type="revolute">
    <origin xyz="0.47 0 0.29" rpy="0 0 0" />
    <parent link="bed_panel_right_leg" />
    <child link="bed_panel_right_leg_lower" />
    <axis xyz="1 0 0" />
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="0.1" />
    <dynamics damping="5" friction="0" />
  </joint>

  <!-- 左大腿板 -->
  <link name="bed_panel_left_leg">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="-0.21 0.00 0.08" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_panel_right_leg_lower_new.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="panel_gray">
        <color rgba="0.85 0.87 0.90 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_panel_left_leg_joint" type="revolute">
    <origin xyz="0.2035 0.16 0.4309" rpy="0 0 0" />
    <parent link="bed_panel_mid" />
    <child link="bed_panel_left_leg" />
    <axis xyz="1 0 0" />
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="0.1" />
    <dynamics damping="5" friction="0" />
  </joint>

  <!-- 左小腿板（独立运动） -->
  <link name="bed_panel_left_leg_lower">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="0.24 0.00 -0.21" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_panel_right_leg_upper_new.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="panel_gray">
        <color rgba="0.85 0.87 0.90 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_panel_left_leg_lower_joint" type="revolute">
    <origin xyz="-0.45 0 0.29" rpy="0 0 0" />
    <parent link="bed_panel_left_leg" />
    <child link="bed_panel_left_leg_lower" />
    <axis xyz="1 0 0" />
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="0.1" />
    <dynamics damping="5" friction="0" />
  </joint>

  <!-- 背板 -->
  <link name="bed_panel_back">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="-0.01 -0.875 0.05" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_panel_back_new.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="panel_gray">
        <color rgba="0.85 0.87 0.90 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_panel_back_joint" type="revolute">
    <origin xyz="0 0.16 -0.13" rpy="0 0 0" />
    <parent link="bed_panel_mid" />
    <child link="bed_panel_back" />
    <axis xyz="1 0 0" />
    <limit lower="-1.2217" upper="1.2217" effort="100" velocity="0.1" />
    <dynamics damping="5" friction="0" />
  </joint>

  <!-- 头板（独立运动） -->
  <link name="bed_head_board">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="-0.01 -1.12 0.26" rpy="0.384 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_head_board_new.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="panel_gray">
        <color rgba="0.85 0.87 0.90 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_head_board_joint" type="revolute">
    <origin xyz="0 0.00 -0.6" rpy="0 0 0" />
    <parent link="bed_panel_back" />
    <child link="bed_head_board" />
    <axis xyz="1 0 0" />
    <limit lower="-1.2217" upper="1.2217" effort="100" velocity="0.1" />
    <dynamics damping="5" friction="0" />
  </joint>

  <!-- 围挡 1 -->
  <link name="bed_enclosure_1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="0 -0.57 -0.1" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_enclosure_1_bin.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="enclosure_silver">
        <color rgba="0.78 0.80 0.84 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_enclosure_1_joint" type="fixed">
    <origin xyz="0.0018 0.5678 0.2837" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="bed_enclosure_1" />
  </joint>

  <!-- 围挡 2 -->
  <link name="bed_enclosure_2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="0 -0.44 -0.1" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_enclosure_2_bin.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="enclosure_silver">
        <color rgba="0.78 0.80 0.84 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_enclosure_2_joint" type="fixed">
    <origin xyz="0.0018 0.4278 0.2837" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="bed_enclosure_2" />
  </joint>

  <!-- 围挡 3 -->
  <link name="bed_enclosure_3">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="0 -0.31 -0.1" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_enclosure_3_bin.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="enclosure_silver">
        <color rgba="0.78 0.80 0.84 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_enclosure_3_joint" type="fixed">
    <origin xyz="0.0018 0.2878 0.2837" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="bed_enclosure_3" />
  </joint>

  <!-- 围挡 4 -->
  <link name="bed_enclosure_4">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
    <visual>
      <origin xyz="0 -0.18 -0.1" rpy="0 0 0" />
      <geometry>
        <mesh filename="/models/surgical_bed_v2/bed_enclosure_4_bin.stl" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="enclosure_silver">
        <color rgba="0.78 0.80 0.84 1.0" />
      </material>
    </visual>
  </link>
  <joint name="bed_enclosure_4_joint" type="fixed">
    <origin xyz="0.0026 0.1478 0.2837" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="bed_enclosure_4" />
  </joint>
</robot>
